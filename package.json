{
  "name": "slackbot-release",
  "version": "2.1.1",
  "description": "Slackbot on release",
  "main": "lib/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "node --import tsx --test tests/*.test.ts",
    "all": "npm run build && npm run format && npm run lint && npm run test && npm run package",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amendx/slackbot-release.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "amendx",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@eslint/js": "^10.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@slack/types": "^2.21.1",
    "@slack/web-api": "^7.16.0",
    "@tryfabric/mack": "^1.2.1",
    "axios": "^1.16.1",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/sinon": "^21.0.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.4.0",
    "js-yaml": "^4.2.0",
    "prettier": "3.8.3",
    "release-it": "^20.0.1",
    "sinon": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
